# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Required for the API server and DB migrations.
# On Replit this is provisioned automatically; for local dev use your own PG instance.
DATABASE_URL=postgresql://user:password@localhost:5432/memoryos

# ── Session ───────────────────────────────────────────────────────────────────
# Secret used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-a-random-string

# ── Local AI (optional) ───────────────────────────────────────────────────────
# Ollama base URL. Leave as-is if running Ollama locally with default settings.
OLLAMA_BASE_URL=http://localhost:11434

# Model names for Ollama
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=gemma3:4b

# ChromaDB base URL. Leave as-is if running ChromaDB locally with default settings.
CHROMADB_URL=http://localhost:8000

# ChromaDB collection name for document embeddings
CHROMADB_COLLECTION=memoryos-documents

# ── API Server ────────────────────────────────────────────────────────────────
# Port the Express API listens on. Defaults to 8080 if not set.
PORT=8080

# Node environment. Use "development" locally; "production" in deployment.
NODE_ENV=development
